<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>النظام الإداري | بحر الغُبُش</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Changa:wght@400;700&display=swap');
        body { font-family: 'Changa', sans-serif; background: #051005; color: #e5e5e5; }
        .glass-panel { background: rgba(10, 30, 10, 0.95); border: 1px solid #145a32; border-radius: 20px; box-shadow: 0 0 20px rgba(46, 204, 113, 0.1); }
        .stat-card { background: #0a1f0a; border-right: 4px solid #2ecc71; padding: 15px; border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen">

    <div id="lockScreen" class="fixed inset-0 bg-black z-[9999] flex items-center justify-center p-6">
        <div class="glass-panel p-8 w-full max-w-sm text-center border-2 border-green-600">
            <div class="w-20 h-20 bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-6 border border-green-500">
                <i class="fas fa-crown text-3xl text-green-500"></i>
            </div>
            <h2 class="text-xl font-bold mb-2">منظومة الإدارة العليا</h2>
            <p class="text-[10px] text-zinc-500 mb-6">خاص بالدكتور عبدالصمد والنائب فقط</p>
            <input type="password" id="passInput" placeholder="كلمة المرور السرية..." class="w-full p-4 bg-black border border-green-900 rounded-xl mb-4 text-center text-white outline-none focus:border-green-500">
            <button onclick="unlock()" class="bg-green-600 text-black w-full py-3 rounded-xl font-bold hover:bg-green-500 transition shadow-lg shadow-green-900/20">تفعيل النظام</button>
        </div>
    </div>

    <div id="adminPanel" style="display:none;">
        <nav class="p-4 border-b border-green-900 bg-zinc-950/80 sticky top-0 backdrop-blur-md z-50">
            <div class="max-w-6xl mx-auto flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <img src="https://i.ibb.co/m5zYv60/logo.png" class="w-8 h-8 opacity-80" onerror="this.style.display='none'">
                    <span class="font-bold text-green-500">بحر الغُبُش <span class="text-white text-xs font-light mr-2">| الإدارة</span></span>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-[10px] bg-green-900/50 px-2 py-1 rounded text-green-400">متصل الآن</span>
                    <button onclick="location.reload()" class="text-red-500 hover:text-red-400"><i class="fas fa-power-off"></i></button>
                </div>
            </div>
        </nav>

        <main class="p-6 max-w-6xl mx-auto">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                <div class="stat-card">
                    <p class="text-[10px] text-zinc-500">طلبات اليوم</p>
                    <h4 class="text-xl font-bold">24 <span class="text-[10px] text-green-500">طلب</span></h4>
                </div>
                <div class="stat-card" style="border-right-color: #f1c40f;">
                    <p class="text-[10px] text-zinc-500">إيصالات معلقة</p>
                    <h4 class="text-xl font-bold text-yellow-500">7 <span class="text-[10px]">تنبيه</span></h4>
                </div>
                <div class="stat-card" style="border-right-color: #3498db;">
                    <p class="text-[10px] text-zinc-500">الزوار حالياً</p>
                    <h4 class="text-xl font-bold text-blue-400">12</h4>
                </div>
                <div class="stat-card" style="border-right-color: #9b59b6;">
                    <p class="text-[10px] text-zinc-500">رصيد اليوم</p>
                    <h4 class="text-xl font-bold">1.2M <span class="text-[10px]">SDG</span></h4>
                </div>
            </div>

            <section class="glass-panel p-6 mb-8">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-bold border-r-2 border-green-500 pr-3">تحديث قائمة الأسعار (SDG)</h3>
                    <button class="text-[10px] bg-green-600 text-black px-3 py-1 rounded-full font-bold">حفظ التغييرات</button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="bg-black/40 p-3 rounded-lg flex justify-between items-center">
                        <span class="text-sm text-zinc-400">سحر الأرحام / السحر الأسود</span>
                        <input type="text" value="75,000" class="w-24 bg-zinc-900 border border-green-900 text-center text-xs p-2 rounded focus:border-green-500 outline-none text-green-400">
                    </div>
                    <div class="bg-black/40 p-3 rounded-lg flex justify-between items-center">
                        <span class="text-sm text-zinc-400">زيت الزيتون المرقي (عبوة)</span>
                        <input type="text" value="15,000" class="w-24 bg-zinc-900 border border-green-900 text-center text-xs p-2 rounded focus:border-green-500 outline-none text-green-400">
                    </div>
                    <div class="bg-black/40 p-3 rounded-lg flex justify-between items-center">
                        <span class="text-sm text-zinc-400">القسط الهندي (مطحون)</span>
                        <input type="text" value="7,500" class="w-24 bg-zinc-900 border border-green-900 text-center text-xs p-2 rounded focus:border-green-500 outline-none text-green-400">
                    </div>
                    <div class="bg-black/40 p-3 rounded-lg flex justify-between items-center">
                        <span class="text-sm text-zinc-400">خلطة عسل "الشفاء"</span>
                        <input type="text" value="30,000" class="w-24 bg-zinc-900 border border-green-900 text-center text-xs p-2 rounded focus:border-green-500 outline-none text-green-400">
                    </div>
                </div>
            </section>

            <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="glass-panel p-6">
                    <h3 class="font-bold mb-4 text-sm"><i class="fas fa-users-cog ml-2"></i> صلاحيات الفريق</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center p-2 border-b border-green-900/30">
                            <span class="text-xs">حساب النائب (كامل الصلاحيات)</span>
                            <span class="text-[10px] text-green-500 italic">نشط</span>
                        </div>
                        <div class="flex justify-between items-center p-2 border-b border-green-900/30">
                            <span class="text-xs">حساب الموظف (إدخال بيانات)</span>
                            <button class="text-[10px] text-red-500">إيقاف مؤقت</button>
                        </div>
                    </div>
                </div>
                <div class="glass-panel p-6 bg-red-900/5 border-red-900/30 text-center flex flex-col justify-center items-center">
                    <i class="fas fa-exclamation-circle text-red-600 text-3xl mb-3"></i>
                    <p class="text-xs text-zinc-400 italic">"هذا القسم مخصص لإصدار التقارير الشهرية للمركز"</p>
                    <button class="mt-4 bg-zinc-900 text-white text-[10px] px-6 py-2 rounded-lg border border-zinc-700">تحميل التقرير PDF</button>
                </div>
            </section>
        </main>
    </div>

    <script>
        function unlock() {
            const pass = document.getElementById('passInput').value;
            // كلمة السر الخاصة بك
            if(pass === "Gubsh@2026") {
                document.getElementById('lockScreen').style.transition = '0.5s';
                document.getElementById('lockScreen').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('lockScreen').style.display = 'none';
                    document.getElementById('adminPanel').style.display = 'block';
                }, 500);
            } else {
                alert("❌ كلمة المرور غير صحيحة.. الوصول مرفوض!");
            }
        }
    </script>
</body>
</html>
